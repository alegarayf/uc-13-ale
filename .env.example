# Copy to `.env` in the repository root (do not commit `.env`).
# `npm run dev` and `npm run dev:*` load this file via dotenv-cli.
# Frontend (Vite) reads `VITE_*` from the repo root via `frontend/vite.config.ts` envDir.

# --- Data store (backend-api) ---
# memory = in-process store for local development
# databricks = connect to Databricks (requires variables below)
DATA_STORE=memory

# --- Service ports ---
FRONTEND_PORT=5173
BACKEND_API_PORT=3001
BACKEND_AI_PORT=8000

# --- API cache (backend-api) ---
# Seconds to cache GET read results (rules list/detail). Set 0 to disable.
API_CACHE_TTL_SECONDS=60

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3001
VITE_AI_API_BASE_URL=http://localhost:8000

# --- Databricks SQL / warehouse (when DATA_STORE=databricks) ---
# DATABRICKS_SERVER_HOSTNAME=adb-xxx.azuredatabricks.net
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx
# DATABRICKS_TOKEN=
# DATABRICKS_CATALOG=main
# DATABRICKS_SCHEMA=default
